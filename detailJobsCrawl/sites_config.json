{
  "topcv": {
    "base_url": "https://www.topcv.vn",
    "list_page_url": "https://www.topcv.vn/tim-viec-lam-moi-nhat-tai-ho-chi-minh-l2",
    "selectors": {
      "list_page": {
        "job_item": "div.box-job-list div.job-item-search-result",
        "next_page_button": "ul.pagination a[rel='next'][data-href]",
        "job_title": "h3.title a",
        "job_url": "h3.title a",
        "company_name": "a.company span.company-name",
        "salary": ".title-salary",
        "location": "label.address",
        "post_date": "label.label-update"
      },
      "detail_page": {
        "wait_for_element": "div.job-detail__information-detail--content",
        "company_name": "div.company-name-label a.name",
        "company_scale": "div.company-scale div.company-value",
        "company_field": "div.company-field div.company-value",
        "company_address": "div.company-address div.company-value",
        "job_level": { "container": ".box-general-group", "title": "Cấp bậc", "value": ".box-general-group-info-value"},
        "education_level": { "container": ".box-general-group", "title": "Học vấn", "value": ".box-general-group-info-value"},
        "quantity_needed": { "container": ".box-general-group", "title": "Số lượng tuyển", "value": ".box-general-group-info-value"},
        "employment_type": { "container": ".box-general-group", "title": "Hình thức làm việc", "value": ".box-general-group-info-value"},
        "gender_requirement": { "container": ".box-general-group", "title": "Giới tính", "value": ".box-general-group-info-value"},
        "job_description": { "container": ".job-description__item", "title": "Mô tả công việc", "value": ".job-description__item--content"},
        "job_requirements": { "container": ".job-description__item", "title": "Yêu cầu ứng viên", "value": ".job-description__item--content"},
        "job_benefits": { "container": ".job-description__item", "title": "Quyền lợi được hưởng", "value": ".job-description__item--content"},
        "working_time": { "container": ".job-description__item", "title": "Thời gian làm việc", "value": ".job-description__item--content"},
        "related_job_categories": { "container": ".box-category", "title": "Danh mục Nghề nghiệp", "value": "a.box-category-tag"},
        "required_skills_tags": { "container": ".box-category", "title": "Kỹ năng cần có", "value": "span.box-category-tag"},
        "preferred_skills_tags": { "container": ".box-category", "title": "Kỹ năng nên có", "value": "span.box-category-tag"},
        "application_deadline": ".job-detail__information-detail--actions-label"
      }
    }
  }
}